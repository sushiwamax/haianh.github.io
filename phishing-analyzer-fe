<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Phishing Email Analyzer — FPT Security</title>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:'Segoe UI',system-ui,sans-serif;background:#f5f5f3;color:#1a1a1a;min-height:100vh}
  a{color:inherit}

  /* Layout */
  header{background:#fff;border-bottom:1px solid #e5e5e0;padding:0 2rem;display:flex;align-items:center;gap:12px;height:56px}
  header .logo{font-size:15px;font-weight:600;color:#1a1a1a}
  header .tag{font-size:11px;background:#fee2e2;color:#991b1b;padding:3px 10px;border-radius:20px;font-weight:500}
  main{max-width:1100px;margin:0 auto;padding:2rem;display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
  @media(max-width:780px){main{grid-template-columns:1fr}}

  /* Cards */
  .card{background:#fff;border:1px solid #e5e5e0;border-radius:12px;padding:1.5rem}
  .card h2{font-size:14px;font-weight:600;color:#6b6b6b;text-transform:uppercase;letter-spacing:.06em;margin-bottom:1rem}

  /* Form */
  label{display:block;font-size:13px;font-weight:500;color:#444;margin-bottom:4px}
  .field{margin-bottom:1rem}
  input[type=text],textarea{width:100%;border:1px solid #ddd;border-radius:8px;padding:10px 12px;font-size:14px;font-family:inherit;color:#1a1a1a;background:#fafafa;transition:border .15s;resize:vertical}
  input[type=text]:focus,textarea:focus{outline:none;border-color:#888;background:#fff}
  textarea{font-family:'Courier New',monospace;font-size:13px}
  .hint{font-size:12px;color:#999;margin-top:3px}

  /* Samples */
  .samples{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1.25rem}
  .sample-btn{border:1px solid #e0e0e0;background:#f9f9f7;border-radius:6px;padding:5px 10px;font-size:12px;cursor:pointer;color:#555;transition:all .15s}
  .sample-btn:hover{background:#f0f0ec;border-color:#ccc}

  /* Analyze button */
  .btn-analyze{width:100%;background:#1a1a1a;color:#fff;border:none;border-radius:8px;padding:12px;font-size:15px;font-weight:500;cursor:pointer;transition:opacity .15s;margin-top:.5rem}
  .btn-analyze:hover{opacity:.85}
  .btn-analyze:disabled{opacity:.5;cursor:not-allowed}

  /* Result panel */
  #result-panel{display:none}
  .score-block{display:flex;align-items:center;gap:1.25rem;padding:1.25rem;border-radius:10px;margin-bottom:1.25rem}
  .score-block.phishing{background:#fef2f2;border:1px solid #fca5a5}
  .score-block.suspicious{background:#fffbeb;border:1px solid #fcd34d}
  .score-block.safe{background:#f0fdf4;border:1px solid #86efac}
  .score-circle{width:64px;height:64px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;flex-shrink:0}
  .score-circle.phishing{background:#fee2e2;color:#991b1b}
  .score-circle.suspicious{background:#fef3c7;color:#92400e}
  .score-circle.safe{background:#dcfce7;color:#166534}
  .verdict-text{font-size:16px;font-weight:600;margin-bottom:4px}
  .verdict-text.phishing{color:#991b1b}
  .verdict-text.suspicious{color:#92400e}
  .verdict-text.safe{color:#166534}
  .summary-text{font-size:13px;color:#555;line-height:1.6}

  /* Findings */
  .findings-list{display:flex;flex-direction:column;gap:8px}
  .finding{border-radius:8px;padding:.75rem 1rem;border-left:3px solid transparent}
  .finding.high{background:#fef2f2;border-color:#f87171}
  .finding.medium{background:#fffbeb;border-color:#fbbf24}
  .finding.low{background:#f0f9ff;border-color:#7dd3fc}
  .finding.safe{background:#f0fdf4;border-color:#86efac}
  .finding-top{display:flex;align-items:center;gap:8px;margin-bottom:3px}
  .finding-badge{font-size:11px;font-weight:600;padding:2px 8px;border-radius:10px}
  .finding-badge.high{background:#fee2e2;color:#991b1b}
  .finding-badge.medium{background:#fef3c7;color:#92400e}
  .finding-badge.low{background:#e0f2fe;color:#075985}
  .finding-badge.safe{background:#dcfce7;color:#166534}
  .finding-cat{font-size:13px;font-weight:500;color:#1a1a1a}
  .finding-desc{font-size:13px;color:#444;margin-bottom:2px}
  .finding-detail{font-size:12px;color:#888;line-height:1.5}

  .no-findings{text-align:center;padding:2rem;color:#aaa;font-size:14px}
  .loading{text-align:center;padding:2rem;color:#888;font-size:14px}
</style>
</head>
<body>

<header>
  <div class="logo">🔍 Phishing Email Analyzer</div>
  <div class="tag">FPT Security Research</div>
</header>

<main>
  <!-- Input Panel -->
  <div class="card">
    <h2>Thông tin email cần phân tích</h2>

    <div style="margin-bottom:1rem">
      <div style="font-size:12px;color:#888;margin-bottom:6px">Thử với mẫu có sẵn:</div>
      <div class="samples">
        <button class="sample-btn" onclick="loadSample('bec')">CEO Fraud</button>
        <button class="sample-btn" onclick="loadSample('urgency')">IT Support giả</button>
        <button class="sample-btn" onclick="loadSample('doubleext')">File .exe giả PDF</button>
        <button class="sample-btn" onclick="loadSample('vendor')">Vendor BEC</button>
        <button class="sample-btn" onclick="loadSample('legit')">Email hợp lệ</button>
      </div>
    </div>

    <div class="field">
      <label>Người gửi (From)</label>
      <input type="text" id="from_header" placeholder="Ví dụ: FPT IT Support <it-support@fpt-helpdesk.net>">
    </div>
    <div class="field">
      <label>Tiêu đề (Subject)</label>
      <input type="text" id="subject" placeholder="Ví dụ: [URGENT] Tài khoản sắp bị khóa">
    </div>
    <div class="field">
      <label>Nội dung email (Body)</label>
      <textarea id="body" rows="7" placeholder="Dán nội dung email vào đây..."></textarea>
    </div>
    <div class="field">
      <label>Email Headers (tùy chọn)</label>
      <textarea id="headers_raw" rows="4" placeholder="Dán raw headers để kiểm tra SPF/DKIM/DMARC..."></textarea>
      <div class="hint">Trong Gmail: More → Show original. Trong Outlook: File → Properties → Internet headers.</div>
    </div>

    <button class="btn-analyze" id="btn" onclick="runAnalysis()">🔎 Phân tích ngay</button>
  </div>

  <!-- Result Panel -->
  <div>
    <div class="card" id="result-panel">
      <h2>Kết quả phân tích</h2>

      <div id="score-block" class="score-block">
        <div id="score-circle" class="score-circle">—</div>
        <div>
          <div id="verdict-text" class="verdict-text"></div>
          <div id="summary-text" class="summary-text"></div>
        </div>
      </div>

      <h2 style="margin-bottom:.75rem">Chi tiết dấu hiệu</h2>
      <div id="findings-list" class="findings-list"></div>
    </div>

    <div class="card" id="placeholder-card" style="margin-top:0">
      <div style="text-align:center;padding:3rem 1rem;color:#bbb">
        <div style="font-size:40px;margin-bottom:1rem">📧</div>
        <div style="font-size:14px">Nhập thông tin email và nhấn<br><strong style="color:#888">Phân tích ngay</strong> để xem kết quả</div>
      </div>
    </div>
  </div>
</main>

<script>
const SAMPLES = {
  bec: {
    from_header: "Trương Gia Bình (CEO FPT) <truong.gia.binh@gmail.com>",
    subject: "Chuyển khoản khẩn — Bảo mật tuyệt đối",
    body: "Em ơi, anh đang trong cuộc họp, không tiện nghe máy. Em chuyển gấp 450 triệu sang tài khoản dưới đây để hoàn tất thương vụ hôm nay. Tuyệt đối không nói với ai, kể cả CFO. STK: 1234567890 Vietcombank.",
    headers_raw: ""
  },
  urgency: {
    from_header: "FPT IT Support <it-support@fpt-helpdesk.net>",
    subject: "[URGENT] Tài khoản FPT ID sắp bị khóa — Xác minh ngay",
    body: "Hệ thống bảo mật phát hiện đăng nhập bất thường. Tài khoản sẽ bị khóa vĩnh viễn trong vòng 24 giờ nếu bạn không xác minh. Nhấn vào link sau để cập nhật mật khẩu ngay lập tức: http://fpt-id-verify.xyz/login?token=a9f3k",
    headers_raw: "From: it-support@fpt-helpdesk.net\nReply-To: attacker@evil.com\nReceived-SPF: fail\nDKIM-Signature: v=1; dkim=fail"
  },
  doubleext: {
    from_header: "Phòng Nhân sự FPT <hr-thongbao@fpt.com.vn>",
    subject: "Thông báo điều chỉnh lương Q4/2024",
    body: "Kính gửi Anh/Chị, phòng nhân sự gửi file bảng lương quý 4. Vui lòng mở file đính kèm: BangLuong_Q4_2024.pdf.exe\nHạn xác nhận: 15/11/2024.",
    headers_raw: ""
  },
  vendor: {
    from_header: "Công ty Đối tác <procurement@supplier-fpt.vn>",
    subject: "Cập nhật tài khoản ngân hàng — Hợp đồng 2024-1102",
    body: "Kính gửi phòng mua hàng, do thay đổi ngân hàng, vui lòng dùng tài khoản mới cho thanh toán từ tháng 12: Techcombank STK 9876543210. Chuyển khoản khẩn cho hóa đơn tháng này nhé.",
    headers_raw: ""
  },
  legit: {
    from_header: "Ban Đào tạo FPT <dao-tao@fpt.edu.vn>",
    subject: "Lịch đào tạo ATTT Q1/2025 — Đăng ký trước 30/11",
    body: "Kính gửi Anh/Chị, theo kế hoạch năm 2025, tất cả nhân sự tham gia khóa đào tạo An toàn thông tin bắt buộc. Đăng ký tại: https://learning.fpt.com.vn/attt-2025. Liên hệ hr@fpt.com.vn nếu có thắc mắc.",
    headers_raw: "Received-SPF: pass\nDKIM-Signature: v=1; dkim=pass\nDMARC: pass"
  }
};

function loadSample(key) {
  const s = SAMPLES[key];
  document.getElementById('from_header').value = s.from_header;
  document.getElementById('subject').value = s.subject;
  document.getElementById('body').value = s.body;
  document.getElementById('headers_raw').value = s.headers_raw;
}

async function runAnalysis() {
  const btn = document.getElementById('btn');
  btn.disabled = true;
  btn.textContent = 'Đang phân tích...';

  document.getElementById('placeholder-card').style.display = 'none';
  document.getElementById('result-panel').style.display = 'block';
  document.getElementById('findings-list').innerHTML = '<div class="loading">Đang phân tích email...</div>';

  const payload = {
    from_header: document.getElementById('from_header').value,
    subject: document.getElementById('subject').value,
    body: document.getElementById('body').value,
    headers_raw: document.getElementById('headers_raw').value,
  };

  try {
    const res = await fetch('/analyze', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    renderResult(data);
  } catch(e) {
    document.getElementById('findings-list').innerHTML = '<div class="no-findings">Lỗi kết nối. Kiểm tra lại server.</div>';
  }

  btn.disabled = false;
  btn.textContent = '🔎 Phân tích ngay';
}

function renderResult(data) {
  const v = data.verdict;
  const sb = document.getElementById('score-block');
  const sc = document.getElementById('score-circle');
  const vt = document.getElementById('verdict-text');

  sb.className = `score-block ${v}`;
  sc.className = `score-circle ${v}`;
  sc.textContent = data.score;
  vt.className = `verdict-text ${v}`;
  vt.textContent = data.verdict_label;
  document.getElementById('summary-text').textContent = data.summary;

  const severityLabel = {high:'Nguy hiểm cao', medium:'Đáng ngờ', low:'Chú ý', safe:'An toàn'};
  const findings = data.findings;

  if (!findings.length) {
    document.getElementById('findings-list').innerHTML = '<div class="no-findings">Không phát hiện dấu hiệu đáng ngờ nào.</div>';
    return;
  }

  // Sắp xếp: high → medium → low → safe
  const order = {high:0, medium:1, low:2, safe:3};
  findings.sort((a,b) => order[a.severity] - order[b.severity]);  

  document.getElementById('findings-list').innerHTML = findings.map(f => `
    <div class="finding ${f.severity}">
      <div class="finding-top">
        <span class="finding-badge ${f.severity}">${severityLabel[f.severity]||f.severity}</span>
        <span class="finding-cat">${f.category}</span>
      </div>
      <div class="finding-desc">${f.description}</div>
      ${f.detail ? `<div class="finding-detail">${f.detail}</div>` : ''}
    </div>
  `).join('');
}
</script>
</body>
</html>
